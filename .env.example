POSTGRES_PASSWORD=replace-with-a-long-random-password
NODE_ENV=production
PORT=3100
SESSION_COOKIE_NAME=wireless_canvas_session
SESSION_TTL_SECONDS=28800
TRUST_PROXY=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=超级管理员
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-12-character-password
MFA_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-base64-32
PROVIDER_ENCRYPTION_KEY=replace-with-a-second-openssl-rand-base64-32
WORKER_CONCURRENCY=10
TASK_MOCK_MODE=false
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=wireless-canvas
S3_ACCESS_KEY_ID=wireless-canvas
S3_SECRET_ACCESS_KEY=replace-with-a-long-random-object-storage-password
S3_FORCE_PATH_STYLE=true
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_CALLBACK_URL=https://canvas.example.com/api/auth/wecom/callback

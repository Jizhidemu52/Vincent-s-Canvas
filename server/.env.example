NODE_ENV=development
PORT=3100
DATABASE_URL=postgres://wireless_canvas:change-me@localhost:5432/wireless_canvas
REDIS_URL=redis://localhost:6379
SESSION_COOKIE_NAME=wireless_canvas_session
SESSION_TTL_SECONDS=28800
TRUST_PROXY=false
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=超级管理员
BOOTSTRAP_ADMIN_PASSWORD=change-this-before-first-run
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_CALLBACK_URL=
# Generate a 32-byte base64 key for external Provider credentials with: openssl rand -base64 32
PROVIDER_ENCRYPTION_KEY=
WORKER_CONCURRENCY=10
TASK_MOCK_MODE=false
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=wireless-canvas
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

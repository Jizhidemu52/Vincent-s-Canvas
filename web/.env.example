# Internal AI credentials stay on the Vite server and are never exposed to browser code.
INTERNAL_AI_APP_KEY=
INTERNAL_AI_SEAMLESS_URL=http://122.247.78.91:8101/std/tohwkdpj

# Optional when administrators configure the service from a non-localhost deployment.
INTERNAL_AI_CONFIG_TOKEN=

# Optional company asset database adapter. Configure these in the admin UI or here.
COMPANY_ASSET_DATABASE_URL=
COMPANY_ASSET_DATABASE_TOKEN=

# Local QA only. When enabled, the proxy returns the uploaded image after a short delay.
INTERNAL_AI_MOCK=false

# Development proxy for the production identity/business API.
VITE_API_PROXY_TARGET=http://localhost:3100
